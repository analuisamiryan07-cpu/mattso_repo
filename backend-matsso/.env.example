# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Backend NestJS (backend-matsso)
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el archivo .env a Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos (Supabase PostgreSQL) ───────────────────────────────────────
# Session Pooler URL — usar para DATABASE_URL (Prisma en producción)
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres"

# Direct connection URL — usar para DIRECT_URL (migraciones Prisma)
DIRECT_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-1-us-west-2.supabase.co:5432/postgres"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
JWT_SECRET="CAMBIA_ESTO_POR_UNA_CLAVE_SECRETA_LARGA_Y_ALEATORIA"

# ── API Key para el panel administrativo ──────────────────────────────────────
# La misma clave debe estar en el backoffice PHP (ADMIN_API_KEY en pagos.php)
ADMIN_API_KEY="CAMBIA_ESTO_POR_UNA_CLAVE_ADMIN_SECRETA"

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL del frontend en Vercel (sin barra final). Separa con comas para múltiples dominios.
FRONTEND_URL="https://tu-proyecto.vercel.app"

# ── Email transaccional (Gmail SMTP vía Nodemailer) ───────────────────────────
# Cuenta Gmail que usará MATSSO para enviar notificaciones a clientes
# Ej: notificaciones.matsso@gmail.com
GMAIL_USER="tucuenta@gmail.com"

# Contraseña de aplicación de Google (NO la contraseña normal de Gmail)
# Cómo obtenerla: myaccount.google.com → Seguridad → Verificación en 2 pasos (activa)
#   → luego busca "Contraseñas de aplicaciones" → App: Correo → Dispositivo: Otro → Generar
# Formato: xxxx xxxx xxxx xxxx (16 caracteres sin espacios al guardarla)
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# ── Cola de trabajos asíncronos (BullMQ + Redis) ──────────────────────────────
# Obtén Redis gratuito en upstash.com → crear database → copiar "Redis URL"
# Formato: redis://default:[token]@[host]:[port]
# Sin esta variable la cola se desactiva y los emails se envían síncronamente
REDIS_URL="redis://default:token@host.upstash.io:port"

# ── Almacenamiento de comprobantes (Supabase Storage) ─────────────────────────
# SUPABASE_URL: Panel Supabase → Settings → API → Project URL
SUPABASE_URL="https://[ref].supabase.co"

# SUPABASE_SERVICE_KEY: Panel Supabase → Settings → API → service_role key
# ⚠ NUNCA exponer en el frontend — tiene permisos totales sobre la base de datos
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
