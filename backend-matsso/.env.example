# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Backend NestJS (backend-matsso)
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el archivo .env a Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de Datos (PostgreSQL Cloud — Supabase / Neon / Railway) ─────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public&sslmode=require
DATABASE_URL="postgresql://postgres:TU_CONTRASENA@db.tuproyecto.supabase.co:5432/postgres?schema=public&sslmode=require"

# ── JWT ─────────────────────────────────────────────────────────────────────
# Genera una clave segura con: openssl rand -base64 64
JWT_SECRET="CAMBIA_ESTO_POR_UNA_CLAVE_SECRETA_LARGA_Y_ALEATORIA"

# ── API Key para el panel de administración local ────────────────────────────
# Esta misma clave debe configurarse en el servidor local (ADMIN_API_KEY en pagos.php)
ADMIN_API_KEY="CAMBIA_ESTO_POR_UNA_CLAVE_ADMIN_SECRETA"

# ── URL del Frontend (para CORS) ─────────────────────────────────────────────
# En producción: tu dominio de Vercel o el dominio personalizado
FRONTEND_URL="https://matsso.vercel.app"

# ── Puerto del servidor ───────────────────────────────────────────────────────
# Render y Railway asignan el puerto automáticamente via la variable PORT.
# En local puedes dejarlo en 3000.
PORT=3000
