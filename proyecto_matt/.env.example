# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Sistema Local PHP (proyecto_matt)
#
# En Linux/Apache: agrega estas variables en /etc/apache2/envvars o en el
# VirtualHost con SetEnv. También puedes usar un archivo .env con vlucas/phpdotenv
# si instalas esa dependencia de Composer.
#
# En Windows/XAMPP: configura en el VirtualHost de httpd-vhosts.conf con SetEnv.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de Datos PostgreSQL LOCAL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=matssoecuador
DB_USER=postgres
DB_PASSWORD=TU_CONTRASENA_LOCAL

# ── API del Backend en la Nube ───────────────────────────────────────────────
# URL base del NestJS desplegado (sin barra final)
BACKEND_URL=https://tu-backend.render.com

# Debe coincidir exactamente con ADMIN_API_KEY configurado en el NestJS
ADMIN_API_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_ADMIN_SECRETA
